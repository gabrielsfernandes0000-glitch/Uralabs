{
  "name": "uralabs-exchange-worker",
  "version": "0.1.0",
  "private": true,
  "description": "Long-running Node worker: mantem WebSockets BingX por user ativo e faz push de fills/balance via Supabase Realtime.",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "ws": "^8.18.0",
    "pako": "^2.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.13",
    "@types/pako": "^2.0.3",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=20"
  }
}
